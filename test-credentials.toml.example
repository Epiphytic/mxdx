# Public Matrix server test credentials.
# Copy this to test-credentials.toml and fill in real values.
# test-credentials.toml is gitignored — never commit real credentials.
#
# Setup:
#   1. Register two accounts on a public Matrix server (e.g., matrix.org)
#   2. Copy this file: cp test-credentials.toml.example test-credentials.toml
#   3. Fill in the credentials below
#   4. Run: cargo test -p mxdx-matrix --test public_server_compat -- --ignored

[server]
url = "https://matrix-client.matrix.org"

[account1]
username = "your-test-user-1"
password = "your-password-here"

[account2]
username = "your-test-user-2"
password = "your-password-here"
