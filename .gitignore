packages/core/wasm/

# Web console build output
packages/web-console/dist/

# Git worktrees
.worktrees/

# E2E test perf output (default path; override with TEST_PERF_OUTPUT)
e2e-results.jsonl

# Local test artifacts
test-results/
test-worker-log.txt
.sqlhistory

# BRAINS runtime state markers (generated by brains:implement)
docs/plans/.state/

# Beads backup files (local dolt snapshots)
.beads/backup/
